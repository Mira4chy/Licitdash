# =====================================================================
# Backend Python (agente_coletor.py + carga_historica.py)
# =====================================================================
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role_aqui

# Coletor diário usa uma chave; carga histórica aceita várias para girar quota.
GEMINI_API_KEY=AIzaSy...
GEMINI_API_KEYS=AIzaSy...chave1,AIzaSy...chave2,AIzaSy...chave3

# =====================================================================
# Frontend (licidash-web/.env.local) — VITE_* são empacotadas no bundle
# =====================================================================
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...anon_aqui
VITE_GEMINI_API_KEY=AIzaSy...

# =====================================================================
# Vercel — definir em Project Settings > Environment Variables.
# NUNCA prefixar com VITE_ (vazaria a chave no bundle do browser).
# =====================================================================
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
SITE_URL=https://licidash.vercel.app
